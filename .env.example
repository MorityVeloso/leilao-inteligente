# Gemini API
# Backend: "aistudio" (API key, 10k RPD) ou "vertex" (GCP, sem limite)
GEMINI_BACKEND=aistudio
GEMINI_API_KEY=your_gemini_api_key_here

# Vertex AI (necessario se GEMINI_BACKEND=vertex)
# GCP_PROJECT_ID=seu-projeto-gcp
# GCP_LOCATION=us-central1

# Processamento
FRAME_INTERVAL_SECONDS=5
CHANGE_THRESHOLD=0.03
OVERLAY_REGION_TOP_PERCENT=62

# Banco de dados
DATABASE_URL=sqlite:///data/leilao.db

# YouTube (opcional)
YT_DLP_COOKIES_FILE=
